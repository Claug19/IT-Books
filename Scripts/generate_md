#!/usr/bin/env bash
set -euo pipefail

REPO_ROOT="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")/.." && pwd)"
README_FILE="$REPO_ROOT/README.md"
IGNORED="*~|.git|.github|.gitignore"
TREE_OUTPUT="$(
      tree -f --dirsfirst --noreport --charset ascii -I "$IGNORED" "$REPO_ROOT/Books" |
            sed "s|$REPO_ROOT/||g; 1{/^Books$/d;}" |
            sed 's/`/|/g; s/    |/|   |/g' |
            sed -e 's/| \+/  /g' -e 's/|-\+/ */g' -e 's:\(* \)\(\(.*/\)\([^/]\+\)\):\1[\4](<\2>):g'
)"

cat > "$README_FILE" <<EOF
<link rel="stylesheet" href="Assets/bootstrap.css" />
<div id="readme-top"/>
<nav>
  <h2>
    <a href="README.md" data-jekyll-path="/">BOOKS</a>&nbsp;
    <a href="ABOUT.md" data-jekyll-path="/about/">ABOUT</a>&nbsp;
    <a href="USAGE.md" data-jekyll-path="/usage/">USAGE</a>
  </h2>
</nav>
<script>
  document.querySelectorAll("a[data-jekyll-path]").forEach(function (link) {
    link.href = link.dataset.jekyllPath;
  });
</script>

## IT Books

$TREE_OUTPUT

<p align="right"><a href="#readme-top">(back to top)</a></p>
EOF
