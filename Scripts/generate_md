#!/bin/bash

# Change folder to parent folder
cd ..

ignored_files="*~|README.md|.git|.github|.gitignore"
tree=$(tree -f --noreport -I '$ignored_files' --charset ascii |
       sed '1{/^\.$/d;}' |
       sed 's/`/|/g' |
       sed 's/    |/|   |/g' |
       sed -e 's/| \+/  /g' -e 's/|-\+/ */g' -e 's:\(* \)\(\(.*/\)\([^/]\+\)\):\1[\4](<\2>):g'
      )
title="# IT books repository\n\n\n"
about="### About:\nThis project contains IT books on various topics collected throughout the years.\n\n\n"
books="### List of books:\n\n\n${tree}"

echo -e "${title}${about}${books}" > README.md

# Change folder back to Scripts folder
cd Scripts
