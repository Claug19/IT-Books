#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
GREEN='\033[0;32m'
RESET='\033[0m'

run_step() {
  local script_name="$1"
  printf "\n${GREEN}Running %s script...${RESET}\n" "$script_name"

  if ! "$SCRIPT_DIR/$script_name"; then
    echo "Error: $script_name script failed."
    exit 1
  fi
}

run_step compress
run_step generate_md
run_step generate_site_pages
printf "\n${GREEN}Update complete!${RESET}\n"
